{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Backend",
      "type": "shell",
      "command": "dotnet build PokemonDraftApi/PokemonDraftApi.csproj -c Debug",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Install Frontend Deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/pokemon-draft" }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/pokemon-draft" },
      "dependsOn": "Install Frontend Deps",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    }
  ]
}
