{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Backend",
      "program": "${workspaceFolder}/pokemon-draft/bin/Debug/net10.0/pokemon-draft-api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/pokemon-draft",
      "stopAtEntry": false,
      "env": { "ASPNETCORE_ENVIRONMENT": "Development" }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend (.NET)"],
      "preLaunchTask": "Start Frontend",
      "postDebugTask": "Stop Frontend",
      "stopAll": true
    }
  ]
}
